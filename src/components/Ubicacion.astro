---
---
<section class="py-20 bg-slate-50" id="ubicacion">
  <div class="max-w-300 mx-auto px-4">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <div class="flex flex-col gap-8">
        <div>
          <h2 class="text-slate-900 text-3xl font-bold leading-tight">Visítanos</h2>
          <div class="h-1.5 w-16 bg-[#5600b2] mt-3 rounded-full"></div>
        </div>
        <div class="space-y-6">

          <div class="flex items-start gap-5">
            <div class="shrink-0 w-10 h-10 bg-[#5600b2]/10 rounded-full flex items-center justify-center">
              <span class="material-symbols-outlined text-[#5600b2]">location_on</span>
            </div>
            <div>
              <p class="font-bold text-slate-900">Dirección</p>
              
              <p class="text-slate-600">Av. Constituyentes de Nuevo León 1201, L-8 Colonia Linda Vista, 67123 Guadalupe, N.L.</p>
            </div>
          </div>

          <div class="flex items-start gap-5">
            <div class="shrink-0 w-10 h-10 bg-[#5600b2]/10 rounded-full flex items-center justify-center">
              <span class="material-symbols-outlined text-[#5600b2]">schedule</span>
            </div>
            <div>
              <p class="font-bold text-slate-900">Horarios</p>
              
              <p class="text-slate-600">Lunes a Viernes: 9:00 AM - 7:00 PM</p>
              <p class="text-slate-600">Sábados: 9:00 AM - 2:00 PM</p>
            </div>
          </div>

        </div>
      </div>

      <div class="w-full h-100 rounded-3xl overflow-hidden border border-slate-200 shadow-lg">
        <iframe
            src="https://www.openstreetmap.org/export/embed.html?bbox=-100.2627%2C25.6948%2C-100.2596%2C25.6964&layer=mapnik&marker=25.6953%2C-100.2613"
            width="100%"
            height="100%"
            style="border: none;"
            loading="lazy"
            title="Ubicación Dental Uno"
        ></iframe>
      </div>

    </div>
  </div>
</section>