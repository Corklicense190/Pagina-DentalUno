<section class="py-20 bg-blue-50/50" id="por-que-nosotros">
  <div class="max-w-300 mx-auto px-4">
    <div class="flex flex-col items-center mb-16 text-center">
      <h2 class="text-slate-900 text-3xl font-bold leading-tight tracking-[-0.015em]">¿Por qué elegir Dental Uno?</h2>
      <div class="h-1.5 w-16 bg-[#5600b2] mt-3 rounded-full"></div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">

      <div class="flex flex-col items-center text-center">
        <div class="w-20 h-20 bg-white shadow-sm rounded-2xl flex items-center justify-center text-[#5600b2] mb-6">
          <span class="material-symbols-outlined text-4xl">precision_manufacturing</span>
        </div>
        <h3 class="text-xl font-bold mb-3 text-slate-900">Tecnología Avanzada</h3>
        <p class="text-slate-600 leading-relaxed">Equipos de última generación para diagnósticos precisos y tratamientos indoloros.</p>
      </div>

      <div class="flex flex-col items-center text-center">
        <div class="w-20 h-20 bg-white shadow-sm rounded-2xl flex items-center justify-center text-[#5600b2] mb-6">
          <span class="material-symbols-outlined text-4xl">workspace_premium</span>
        </div>
        <h3 class="text-xl font-bold mb-3 text-slate-900">Experiencia Certificada</h3>
        <p class="text-slate-600 leading-relaxed">Especialistas con trayectoria nacional y constante capacitación clínica.</p>
      </div>

      <div class="flex flex-col items-center text-center">
        <div class="w-20 h-20 bg-white shadow-sm rounded-2xl flex items-center justify-center text-[#5600b2] mb-6">
          <span class="material-symbols-outlined text-4xl">volunteer_activism</span>
        </div>
        <h3 class="text-xl font-bold mb-3 text-slate-900">Atención Humana</h3>
        <p class="text-slate-600 leading-relaxed">Trato personalizado y cercano para que te sientas cómodo en cada visita.</p>
      </div>

    </div>
  </div>
</section>